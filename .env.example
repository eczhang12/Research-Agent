# Copy this file to `.env` and replace placeholder values with real secrets.
# The app reads these values through Docker Compose and `config.py`.

# OpenAI is used for query generation, source sufficiency checks, and final
# answer synthesis.
OPENAI_API_KEY=your-openai-api-key

# Tavily is used for web search.
TAVILY_API_KEY=your-tavily-api-key

# The OpenAI model used by every LLM call.
OPENAI_MODEL=gpt-5.4-mini

# Set to true to print step-by-step agent internals in the terminal.
DEBUG=false

# Maximum number of search/check/follow-up research rounds.
MAX_ITERATIONS=3
